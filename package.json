{
  "name": "musicafe-firestore-manager",
  "version": "1.0.0",
  "private": true,
  "description": "MusiCafé: POS, inventario, clientes, ventas y gastos con Firebase Hosting + Firestore.",
  "scripts": {
    "serve": "firebase emulators:start --only hosting,firestore",
    "deploy": "firebase deploy --only hosting,firestore:rules,firestore:indexes",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "devDependencies": {
    "firebase-tools": "latest"
  }
}
